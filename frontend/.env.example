DISABLE_ESLINT_PLUGIN=true
REACT_APP_GOOGLE_MAPS_KEY=Your_Google_Maps_Key_Here
GENERATE_SOURCEMAP=false

# Development: http://localhost:5001
# Production (same domain — leave empty or set to https://www.smarthrms.cloud)
# In production build the app auto-detects same-origin, so you can leave this empty.
REACT_APP_API_URL=http://localhost:5001

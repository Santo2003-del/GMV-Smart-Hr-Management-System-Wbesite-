# ================= SERVER =================
PORT=5001
# Development: 'development'
# Production (VPS with domain): 'production'
NODE_ENV=development

# ================= DATABASE =================
MONGO_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/GMVHRMS?retryWrites=true&w=majority

# ================= JWT =================
JWT_SECRET=your_jwt_secret_key
JWT_EXPIRES=7d

# ================= SUPER ADMIN (ROOT) =================
SUPER_ADMIN_EMAIL=admin@example.com
SUPER_ADMIN_PASSWORD=your_secure_password_here

# ================= FRONTEND =================
# Development: http://localhost:3001
# Production (same domain): https://www.smarthrms.cloud
FRONTEND_URL=http://localhost:3001

# ================= EMAIL (SMTP) =================
# For Gmail: Use App Password (https://myaccount.google.com/apppasswords)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
